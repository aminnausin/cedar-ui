{
    "name": "cedar-ui",
    "type": "module",
    "version": "0.0.2",
    "private": false,
    "packageManager": "pnpm@9.15.9",
    "license": "AGPL-3.0",
    "repository": "aminnausin/cedar-ui",
    "workspaces": [
        "packages/*"
    ],
    "engines": {
        "pnpm": ">=9.6.0"
    },
    "scripts": {
        "docs:dev": "pnpm --filter www dev",
        "docs:build": "pnpm --filter www build",
        "docs:preview": "pnpm --filter www preview",
        "pkg:build": "pnpm --filter @aminnausin/cedar-ui build",
        "pkg:bump": "pnpm --filter @aminnausin/cedar-ui version patch",
        "pkg:beta": "cd packages/cedar-ui && pnpm pub:beta",
        "pkg:release": "cd packages/cedar-ui && pnpm pub:release",
        "prepare": "pnpm simple-git-hooks",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "build:registry": "pnpm --filter=www build:registry",
        "test": "pnpm --filter @aminnausin/cedar-ui test",
        "bumpp": "bumpp package.json packages/*/package.json apps/*/package.json",
        "taze": "taze major -frI --exclude typescript,/@iconify/",
        "taze:minor": "taze minor -fwri --exclude /@iconify/"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@eslint/js": "^9.39.4",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.7.0",
        "bumpp": "^10.4.1",
        "eslint": "^9.39.1",
        "eslint-plugin-vue": "~10.9.0",
        "globals": "^16.5.0",
        "lint-staged": "^16.4.0",
        "prettier": "3.5.3",
        "prettier-plugin-tailwindcss": "^0.7.3",
        "simple-git-hooks": "^2.13.1",
        "taze": "^19.11.0",
        "typescript": "catalog:",
        "vitest": "^3.2.4"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "pnpm": {
        "overrides": {
            "deep-equal": "npm:@nolyfill/deep-equal@^1.0.44",
            "hasown": "npm:@nolyfill/hasown@^1.0.44",
            "is-core-module": "npm:@nolyfill/is-core-module@^1.0.39",
            "is-generator-function": "npm:@nolyfill/is-generator-function@^1.0.44",
            "isarray": "npm:@nolyfill/isarray@^1.0.44",
            "safe-buffer": "npm:@nolyfill/safe-buffer@^1.0.44",
            "safer-buffer": "npm:@nolyfill/safer-buffer@^1.0.44",
            "side-channel": "npm:@nolyfill/side-channel@^1.0.44",
            "typedarray": "npm:@nolyfill/typedarray@^1.0.44",
            "esbuild@<=0.24.2": ">=0.25.0",
            "vite@<=5.4.19": ">=5.4.20",
            "vite@>=5.2.6 <=5.4.20": ">=5.4.21",
            "vite@>=6.0.0 <=6.4.0": ">=6.4.1",
            "preact@>=10.26.5 <10.26.10": ">=10.26.10",
            "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
            "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
            "mdast-util-to-hast@>=13.0.0 <13.2.1": ">=13.2.1",
            "minimatch@<3.1.3": ">=3.1.3",
            "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
            "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
            "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
            "picomatch@<2.3.2": ">=2.3.2",
            "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
            "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
            "lodash@<=4.17.23": ">=4.18.0",
            "vite@<=6.4.1": ">=6.4.2",
            "vite@>=6.0.0 <=6.4.1": ">=6.4.2",
            "postcss@<8.5.10": ">=8.5.10"
        }
    },
    "simple-git-hooks": {
        "pre-commit": "pnpm lint-staged",
        "commit-msg": "pnpm commitlint --edit ${1}"
    },
    "lint-staged": {
        "*": "eslint --fix"
    }
}
